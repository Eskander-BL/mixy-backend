# Base
DATABASE_URL=
NODE_ENV=production
PORT=3000

# Auth / session (si utilisés)
JWT_SECRET=

# Stripe — obligatoire pour les vrais paiements (même paire Test ou Live partout)
STRIPE_SECRET_KEY=
# ID du prix récurrent (Products → ton abonnement → API ID du prix, ex. price_...)
STRIPE_PRICE_ID=
# Signing secret du webhook (Developers → Webhooks → ton endpoint)
STRIPE_WEBHOOK_SECRET=

# CORS : origines en plus des valeurs par défaut (séparateur virgule, sans slash final)
# ALLOWED_ORIGINS=https://staging.example.com
