# --- Base ---
DATABASE_URL=
NODE_ENV=production
PORT=3000

# Auth / session (si login email ou JWT utilisés)
JWT_SECRET=

# OAuth distant (optionnel : laisse vide si tu n’utilises pas ce flux)
# OAUTH_SERVER_URL=

# --- Stripe (même mode partout : tout Test OU tout Live) ---
# Clé secrète : Developers → API keys
STRIPE_SECRET_KEY=
# Prix d’abonnement récurrent : Products → [ton produit] → Pricing → API ID (price_...)
STRIPE_PRICE_ID=
# Secret du webhook : Developers → Webhooks → endpoint → Signing secret (whsec_...)
# L’URL de l’endpoint à enregistrer dans Stripe : https://api.TON_DOMAINE/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# --- CORS ---
# Origines supplémentaires (virgule, sans slash final). Les domaines mixy.com / mixyia.com + Vercel
# sont déjà inclus dans le code ; ajoute ici staging, preview Vercel, etc.
# ALLOWED_ORIGINS=https://preview-xxx.vercel.app

# --- E-mails « Contact » (formulaire app) ---
# Compte gratuit : https://resend.com → API Keys → coller ici.
RESEND_API_KEY=
# Ta boîte pro qui reçoit les messages (ex. support@mixyia.com ou ton Gmail pro).
CONTACT_NOTIFY_EMAIL=
# Expéditeur (domaine à vérifier dans Resend pour la prod). En test sans domaine :
# Mixy <onboarding@resend.dev> (limitations selon doc Resend).
# MAIL_FROM=Mixy <contact@mixyia.com>

# Optionnel : ancien canal Manus / Forge (si encore utilisé en secours).
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
